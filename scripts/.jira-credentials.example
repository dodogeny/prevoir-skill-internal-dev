# .jira-credentials
# Jira API credentials for poll-jira.sh
#
# SETUP:
# 1. Copy this file: cp .jira-credentials.example .jira-credentials
# 2. Replace the dummy values below with your real credentials
# 3. Secure it:       chmod 600 .jira-credentials
#
# Get your API token at: https://id.atlassian.com/manage-profile/security/api-tokens
#
# WARNING: Never commit .jira-credentials — it is listed in .gitignore

JIRA_USER="firstname.lastname@prevoir.mu"
JIRA_TOKEN="your-api-token-here"
