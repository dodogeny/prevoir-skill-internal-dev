{
  "permissions": {
    "allow": [
      "Bash(python3 *)",
      "Bash(xargs cat *)",
      "Skill(update-config)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/load-env.sh",
            "statusMessage": "Loading .env..."
          }
        ]
      }
    ]
  }
}
